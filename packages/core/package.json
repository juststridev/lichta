{
  "name": "@lichta/core",
  "version": "2.2.1",
  "description": "Thư viện lõi tính toán Dương lịch ↔ Âm lịch Việt Nam",
  "author": "Zeforc Labs | Stridev",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    },
    "./styles/*": "./styles/*"
  },
  "files": [
    "dist",
    "styles",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.6",
    "tsup": "^8.0.0",
    "typescript": "^6.0.0",
    "vitest": "^3.2.6"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeforc/lichta.git"
  },
  "bugs": {
    "url": "https://github.com/zeforc/lichta/issues"
  },
  "homepage": "https://github.com/zeforc/lichta#readme"
}
